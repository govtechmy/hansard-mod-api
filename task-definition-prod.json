{
  "containerDefinitions": [
    {
      "environment": [],
      "essential": true,
      "image": "602670427499.dkr.ecr.ap-southeast-5.amazonaws.com/hsd-mod-api-prod:latest",
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": { "awslogs-group": "/ecs/hsd-mod-api-prod", "awslogs-region": "ap-southeast-5", "awslogs-stream-prefix": "ecs" }
      },
      "mountPoints": [],
      "name": "hsd-mod-api",
      "portMappings": [{ "containerPort": 3000, "hostPort": 3000, "name": "hsd-mod-api", "protocol": "tcp" }],
      "stopTimeout": 2,
      "systemControls": [],
      "volumesFrom": []
    }
  ],
  "cpu": "1024",
  "executionRoleArn": "arn:aws:iam::602670427499:role/hsd-ecsTaskExecutionRole-prod",
  "family": "hsd-mod-api-prod",
  "memory": "2048",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "taskRoleArn": "arn:aws:iam::602670427499:role/hsd-ecs-task-role-prod"
}
